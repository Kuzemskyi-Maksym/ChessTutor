        <!-- EditorForm composes Board -->
        <mxCell id="e_ef_b" value="1  EditedBoard" style="endArrow=open;startArrow=diamondThin;startFill=1;startSize=10;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;entryX=1;entryY=0.7;" edge="1" parent="1" source="editorform" target="board">
          <mxGeometry relative="1" as="geometry"/>
