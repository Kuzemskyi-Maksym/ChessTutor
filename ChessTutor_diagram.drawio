        <mxCell id="e_c_b" value="1  Board" style="endArrow=open;startArrow=diamondThin;startFill=1;startSize=10;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.3;entryX=1;entryY=0.4;" edge="1" parent="1" source="controller" target="board">
