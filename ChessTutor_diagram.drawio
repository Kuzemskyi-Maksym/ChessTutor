        <mxCell id="e_rf_b" value="1  _board" style="endArrow=open;startArrow=diamondThin;startFill=1;startSize=10;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="replayform" target="board">
