        <!-- Board ..> Position -->
        <mxCell id="d_b_pos" style="endArrow=open;dashed=1;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="board" target="position">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Validator ..> Move (генерує) -->
        <mxCell id="d_v_m" style="endArrow=open;dashed=1;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="validator" target="move">
