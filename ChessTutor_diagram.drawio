        <mxCell id="e_gs_m" value="*  MoveHistory" style="endArrow=open;startArrow=diamondThin;startFill=0;startSize=10;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.1;entryX=0;entryY=0.5;" edge="1" parent="1" source="gamestate" target="move">
