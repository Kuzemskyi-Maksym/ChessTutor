        <mxCell id="d_pgn_gs" style="endArrow=open;dashed=1;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="pgn" target="gamestate">
