        <!-- MainForm composes GameController -->
        <mxCell id="e_mf_c" value="1  _controller" style="endArrow=open;startArrow=diamondThin;startFill=1;startSize=10;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="mainform" target="controller">
          <mxGeometry relative="1" as="geometry"/>
