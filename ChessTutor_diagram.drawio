        <mxCell id="d_mf_rf" style="endArrow=open;dashed=1;html=1;rounded=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="mainform" target="replayform">
          <mxGeometry relative="1" as="geometry"/>
